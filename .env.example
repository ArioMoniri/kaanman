# === CerebraLink Configuration ===

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Exa API Key (for latest medical guidelines search)
EXA_API_KEY=exa-...

# Redis (MCP Memory Store) — internal Docker network, no change needed
REDIS_URL=redis://redis:6379/0

# Medical MCP Server — internal Docker network
MEDICAL_MCP_URL=http://medical-mcp:3001

# Model Configuration (Claude model IDs)
MODEL_ROUTER=claude-haiku-4-5-20251001
MODEL_PHI_MASKER=claude-haiku-4-5-20251001
MODEL_CLINICAL=claude-opus-4-6
MODEL_RESEARCH=claude-sonnet-4-6
MODEL_DRUG=claude-sonnet-4-6
MODEL_COMPOSER=claude-sonnet-4-6
MODEL_TRUST=claude-haiku-4-5-20251001

# Exposed ports (host:container)
# Frontend: http://localhost:3100
# Backend:  http://localhost:8100
# Redis:    localhost:6380
# Med MCP:  localhost:3101
BACKEND_PORT=8100
FRONTEND_PORT=3100

# Cerebral Plus (patient data source)
CEREBRAL_HOST=cerebralplustr.acibadem.com.tr
